rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Helper functions
    // ============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ============================================================
    // Users
    // ============================================================
    match /users/{userId} {
      allow read, write: if true;

      match /search_history/{docId} {
        allow read, write: if true;
      }
    }

    // ============================================================
    // Customer profiles
    // ============================================================
    match /customer_profiles/{userId} {
      allow read, write: if true;

      match /addresses/{docId} {
        allow read, write: if true;
      }
      match /payment_methods/{docId} {
        allow read, write: if true;
      }
      match /notifications/{docId} {
        allow read, write: if true;
      }
      match /cart/{docId} {
        allow read, write: if true;
      }
      match /my_vouchers/{docId} {
        allow read, write: if true;
      }
    }

    // ============================================================
    // Orders
    // ============================================================
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // ============================================================
    // Driver profiles
    // ============================================================
    match /driver_profiles/{userId} {
      allow read, write: if true;

      match /notifications/{docId} {
        allow read, write: if true;
      }
    }

    // ============================================================
    // Merchant profiles
    // ============================================================
    match /merchant_profiles/{userId} {
      allow read, write: if true;

      match /notifications/{docId} {
        allow read, write: if true;
      }
    }

    // ============================================================
    // Order requests (driver-side)
    // ============================================================
    match /order_requests/{driverId} {
      allow get, list: if isOwner(driverId);
      allow create, update: if false;

      match /requests/{requestId} {
        allow get, list: if isOwner(driverId);
        allow delete: if isOwner(driverId);
        allow create, update: if false;
      }
    }

    // ============================================================
    // Stores and products
    // ============================================================
    match /stores/{storeId} {
      allow read: if true;
      allow write: if false;

      match /products/{productId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // ============================================================
    // Categories
    // ============================================================
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // ============================================================
    // Vouchers
    // ============================================================
    match /vouchers/{voucherId} {
      allow read: if true;
      allow write: if false;
    }

    // System vouchers (voucher doi diem)
    match /system_vouchers/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ============================================================
    // Banners
    // ============================================================
    match /banners/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ============================================================
    // Catch-all: mat dinh khong cho phep cac collection khac
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
